{
  "args": {
    "data_dir": "ml/data/plantvillage",
    "epochs": 12,
    "batch_size": 64,
    "img_size": 160,
    "model": "mobilenet_v3_small",
    "out_dir": "ml/artifacts/cnn_strong_v2",
    "lr": 0.0003,
    "weight_decay": 0.0001,
    "pretrained": true,
    "label_smoothing": 0.03,
    "class_weight_method": "effective",
    "class_weight_beta": 0.999,
    "class_weight_power": 1.0,
    "loss": "ce",
    "target_encoding": "index",
    "focal_gamma": 2.0,
    "focal_alpha": 1.0,
    "mixup": 0.05,
    "mixup_end": 0.0,
    "cutmix": 0.0,
    "cutmix_end": 0.0,
    "cutmix_prob": 0.5,
    "mixup_off_epochs": 3,
    "early_stop": 6,
    "early_stop_min_delta": 0.0015,
    "min_epochs": 8,
    "overfit_gap_threshold": 0.12,
    "overfit_patience": 2,
    "overfit_lr_decay": 0.7,
    "seed": 42,
    "deterministic": false,
    "balanced_sampler": true,
    "sampler_power": 0.9,
    "freeze_epochs": 2,
    "warmup_epochs": 1,
    "grad_accum": 1,
    "randaugment_level": 1,
    "ema_decay": 0.995,
    "ema_decay_start": 0.97,
    "ema_warmup_epochs": 1,
    "backbone_lr_mult": 0.6,
    "head_lr_mult": 1.0,
    "tta": 1,
    "channels_last": false,
    "torch_compile": false,
    "swa_start": -1,
    "swa_lr": 1e-05,
    "progressive_resize": false,
    "final_img_size": 320,
    "resize_switch_epoch": 8,
    "resume": "",
    "save_every": 0,
    "save_metrics": true,
    "workers": 0
  },
  "torch_version": "2.10.0",
  "cuda_available": false,
  "device": "cpu"
}