{
  "name": "bitki-hastalik-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/local-notifications": "^6.0.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^13.5.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.562.0",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^6.10.1",
    "onnxruntime-node": "^1.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-scripts": "5.0.1",
    "sharp": "^0.33.5",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "bash scripts/start-dev.sh",
    "start:all": "concurrently -n API,WEB -c green,cyan \"npm run server\" \"react-scripts start\"",
    "start:web": "react-scripts start",
    "server": "HOST=${HOST:-0.0.0.0} PORT=${API_PORT:-5051} node server/index.js",
    "dev": "npm start",
    "build": "CI=false react-scripts build",
    "build:web": "REACT_APP_FRONTEND_ONLY=true CI=false react-scripts build",
    "presentation:check": "node scripts/presentation-check.mjs",
    "presentation:runbook": "cat docs/PRESENTATION_RUNBOOK.md",
    "cap:sync": "npx cap sync",
    "ios:sync": "npm run build && LANG=en_US.UTF-8 ./node_modules/.bin/cap sync ios",
    "cap:assets": "npx capacitor-assets generate",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-unused-vars": "warn"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
